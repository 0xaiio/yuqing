APP_NAME=Cross Source AI Photo Manager
API_PREFIX=/api/v1
DATABASE_URL=sqlite:///D:/code-repos/yuqing/data/app.db
IMPORT_ROOT=D:/code-repos/yuqing/data/imports
SEARCH_UPLOAD_ROOT=D:/code-repos/yuqing/data/search-uploads
PERSON_LIBRARY_ROOT=D:/code-repos/yuqing/data/person-library
WECHAT_DEFAULT_PATH=
QQ_DEFAULT_PATH=
AI_ENABLE_OCR=true
AI_OCR_ENGINE=rapidocr
AI_ENABLE_VISION=false
AI_VISION_BASE_URL=https://api.openai.com/v1
AI_VISION_API_KEY=
AI_VISION_MODEL=
