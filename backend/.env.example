WATCHER_ENABLED=true
WATCHER_RECURSIVE=true
WATCHER_DEBOUNCE_SECONDS=3
FACE_CLUSTER_SIMILARITY_THRESHOLD=0.86
PERSON_RECOGNITION_SIMILARITY_THRESHOLD=0.84
